{
  "experiments_runner": {
    "default_max_jobs_per_gpu": 1,
    "max_retry_count": 2,
    "heartbeat_stale_sec": 120,
    "memory_check_interval_sec": 3
  },
  "preprocess": {
    "loop_interval_sec": 10,
    "watch_page_size": 20,
    "watch_page": 1,
    "gate_batch_size": 256
  },
  "experiment_env": {},
  "condition_nodes": {
    "nodes": [
      {
        "name": "G0_SENIOR_CONTRACT",
        "description": "Senior contract gate — all downstream experiments gated by this."
      },
      {
        "name": "G1_PHASE3_SENTINEL",
        "description": "Phase 3 sentinel gate.",
        "condition_parent": "G0_SENIOR_CONTRACT"
      },
      {
        "name": "G2_PHASE1_SMOKE_A",
        "description": "Phase 1 smoke test A.",
        "condition_parent": "G0_SENIOR_CONTRACT"
      },
      {
        "name": "G3_PHASE1_SMOKE_B",
        "description": "Phase 1 smoke test B.",
        "condition_parent": "G0_SENIOR_CONTRACT"
      },
      {
        "name": "D1_PHASE1_ROOT_CAUSE",
        "description": "Root cause diagnosis gate after phase 1.",
        "condition_parent": "G2_PHASE1_SMOKE_A",
        "depends_on": ["G3_PHASE1_SMOKE_B"]
      }
    ]
  },
  "staged_matrix": {
    "enabled": true,
    "manifest_path": "configs/staged_matrix_entries.json",
    "condition_parent": "D1_PHASE1_ROOT_CAUSE",
    "role": "staged_matrix_leaf"
  }
}
